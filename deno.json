{
  "imports": {
    "std/": "https://deno.land/std@0.224.0/",
    "vitest": "npm:vitest@^2.1.0",
    "vitest/config": "npm:vitest@^2.1.0/config",
    "@testing-library/svelte": "npm:@testing-library/svelte@^5.2.0",
    "@testing-library/jest-dom/vitest": "npm:@testing-library/jest-dom@^6.5.0/vitest",
    "jsdom": "npm:jsdom@^25"
  },
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve": "deno run --allow-net --allow-read --allow-sys jsr:@std/http/file-server dist/",
    "test": "deno run -A --node-modules-dir npm:vitest@^2.1.0 run"
  },
  "lint": {
    "include": ["src/"],
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"]
    }
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 80,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/"]
  }
}
